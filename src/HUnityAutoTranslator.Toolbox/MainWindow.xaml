<Window x:Class="HUnityAutoTranslator.Toolbox.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="HUnityAutoTranslator 工具箱"
        Width="1280"
        Height="840"
        MinWidth="980"
        MinHeight="680"
        Icon="Assets/branding/hunity-icon-blue-white.ico"
        Loaded="OnLoaded">
    <Grid>
        <wv2:WebView2 x:Name="WebView" />
        <Border x:Name="Fallback"
                Visibility="Collapsed"
                Background="#f3f6fb"
                Padding="32">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="620">
                <Image Source="Assets/branding/hunity-icon-blue-white-128.png"
                       Width="88"
                       Height="88"
                       Margin="0,0,0,18" />
                <TextBlock Text="无法启动工具箱界面"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#161b22"
                           TextAlignment="Center" />
                <TextBlock x:Name="FallbackMessage"
                           Margin="0,12,0,0"
                           TextWrapping="Wrap"
                           Foreground="#5c6878"
                           FontSize="14"
                           TextAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
